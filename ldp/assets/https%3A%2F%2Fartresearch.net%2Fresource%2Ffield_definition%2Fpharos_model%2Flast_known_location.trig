  _:genid-c68c97fd88ea465cbf9937d3c509974d-8jpiih a <http://spinrdf.org/sp#Query>;
    <http://spinrdf.org/sp#text> """PREFIX crm: <http://www.cidoc-crm.org/cidoc-crm/>

SELECT ?value WHERE {
  {
    {
      ?parent crm:P55_has_current_location ?value .
      ?value crm:P2_has_type/crm:P127_has_broader_term* <https://artresearch.net/resource/pharos/vocab/meta/geographical_entity> .
      ?subject crm:P46i_forms_part_of* ?parent .
    }

    # architectural objects don't have \"Last Known Location\" they have \"Location\"
    MINUS { 
      ?subject crm:P2_has_type <https://artresearch.net/resource/pharos/vocab/meta/built_work> .  
    }
  }
}""" .
  
