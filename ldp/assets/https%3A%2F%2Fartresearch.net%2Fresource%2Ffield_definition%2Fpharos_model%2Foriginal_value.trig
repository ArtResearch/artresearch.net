  _:genid-c0d8fea2206f4bb8be340a4adaf09576-5ykhea a <http://spinrdf.org/sp#Query>;
    <http://spinrdf.org/sp#text> """PREFIX crm: <http://www.cidoc-crm.org/cidoc-crm/>

SELECT DISTINCT ?value ?provUri WHERE {
  {
    OPTIONAL {
      ?object crm:P108i_was_produced_by/crm:P9i_forms_part_of* ?production .
    }

    OPTIONAL {
      ?object crm:P65_shows_visual_item ?visualItem .
    }
  }
  
  BIND(IF(?attributedType = crm:P2_has_type || ?attributedType = crm:P45_consists_of || ?attributedType = crm:P50_has_current_keeper || ?attributedType = crm:P55_has_current_location, ?object, IF(?attributedType = crm:P65_shows_visual_item, ?visualItem, ?production)) as ?attributedEntity)
  
  BIND(IF(?attributedType = crm:P65_shows_visual_item, crm:P2_has_type, ?attributedType) AS ?realProperty)
  
  BIND(IRI(CONCAT(\"https://artresearch.net/resource/e13/\", SHA256(CONCAT(STR(?attributedEntity), STR(?realProperty), STR(?subject))))) AS ?attribution)

  {
    ?attribution crm:P134_continued* ?provUri .
    ?provUri crm:P9i_forms_part_of ?cataloging .
    ?cataloging crm:P2_has_type <http://vocab.getty.edu/aat/300054628> .
    ?provUri crm:P141_assigned ?value .
  }
  FILTER(?subject != ?value)
}""" .
  
  _:genid-c0d8fea2206f4bb8be340a4adaf09576-tvkafx a <http://spinrdf.org/sp#Query>;
    <http://spinrdf.org/sp#text> "INSERT { $subject ?predicate $value} WHERE {}" .
  
  <http://www.researchspace.org/resource/system/fieldDefinitionContainer> <http://www.w3.org/ns/ldp#contains>
      <https://artresearch.net/resource/field_definition/pharos_model/original_value> .
}
