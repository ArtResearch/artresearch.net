  _:genid-041f922152ee48cd9a6196ab1cce6a59-rl7vno a <http://spinrdf.org/sp#Query>;
    <http://spinrdf.org/sp#text> """PREFIX crm: <http://www.cidoc-crm.org/cidoc-crm/>
PREFIX pharos-meta: <https://artresearch.net/resource/pharos/vocab/meta/>

SELECT ?value WHERE {
  {
    ?subject crm:P108i_was_produced_by ?part .
    ?part crm:P9_consists_of* ?production .
    ?production a crm:E7_Activity .
    ?production crm:P14_carried_out_by ?value .
    MINUS {
      ?value crm:P2_has_type <https://artresearch.net/resource/pharos/vocab/meta/culture> .
    }
  }
}""" .
  
